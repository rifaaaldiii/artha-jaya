# Production .gitignore for hosting
# Add this to your GitHub repository

# Laravel
/vendor/
/node_modules/
.env
/public/hot
/public/storage
/storage/*.key
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/bootstrap/cache/*

# IDE
/.idea/
/.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# NPM
npm-debug.log
yarn-error.log

# Build files (keep in local, ignore in repo)
# Uncomment jika tidak ingin track build files
# /public/build/
